# ── Servidor ──────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Base de datos ─────────────────────────────────────────────────
# Ruta al archivo SQLite. Por defecto: ./data/markethub.db
DB_PATH=./data/markethub.db

# ── Autenticación JWT ─────────────────────────────────────────────
# Cambia este valor en producción (mínimo 32 caracteres)
JWT_SECRET=markethub-super-secret-jwt-key-cambiar-en-produccion

# ── Stripe (pagos) ────────────────────────────────────────────────
# Obtén tus keys en https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Email (Resend) ────────────────────────────────────────────────
# Obtén tu API key en https://resend.com
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@markethub.mx

# ── Almacenamiento de imágenes ────────────────────────────────────
# Cloudinary (opcional, para imágenes de productos)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
